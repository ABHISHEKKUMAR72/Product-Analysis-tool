# .env.example
# Create a copy of this file, name it .env, and fill in your actual database credentials.
# Do NOT commit your actual .env file to GitHub.

# PostgreSQL Connection String Format:
# postgresql://<username>:<password>@<host>:<port>/<database_name>

# Example for a local PostgreSQL server:
DATABASE_URL=postgresql://postgres:mysecretpassword@localhost:5432/ecommerce

# Example for a remote Neon / Supabase server:
# DATABASE_URL=postgresql://user:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres
